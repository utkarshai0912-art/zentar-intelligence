# ─── Supabase (required) ───
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── AI Provider (required for generation) ───
AI_API_KEY=sk-...                      # OpenAI or Anthropic API key
AI_API_PROVIDER=openai                 # "openai" or "anthropic"
AI_MODEL=gpt-4o-mini                   # Model name

# ─── Razorpay (required for payments) ───
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ─── Admin ───
NEXT_PUBLIC_ADMIN_PASSWORD=admin123    # CHANGE THIS

# ─── App URL ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
